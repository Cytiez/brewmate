# Supabase — anon key is safe client-side by design; never put service_role here or in code.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenRouter — server-side only; consumed by /app/api/logs and /app/api/suggest
OPENROUTER_API_KEY=your-openrouter-api-key
# Optional override; defaults to google/gemma-2-9b-it:free
# OPENROUTER_MODEL=google/gemma-2-9b-it:free

# Optional: used as the HTTP-Referer header sent to OpenRouter for attribution.
# NEXT_PUBLIC_SITE_URL=https://brewmate.example.com
